<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SmartParkingLot.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (Mica drag region) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="20" Height="20" CornerRadius="4"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    VerticalAlignment="Center" Margin="0,0,10,0">
                <Border Width="11" Height="11" CornerRadius="1"
                        BorderBrush="White" BorderThickness="1.5"
                        VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Border>
            <TextBlock x:Name="AppTitleText"
                       Grid.Column="1"
                       Text="Smart Parking Lot — Admin Console"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource Tx2Brush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Navigation shell -->
        <NavigationView x:Name="Nav"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        OpenPaneLength="240"
                        SelectionChanged="Nav_SelectionChanged">

            <NavigationView.PaneHeader>
                <StackPanel Padding="12,8,12,4" Spacing="2">
                    <TextBlock Text="PARQUEADERO"
                               Style="{StaticResource SectionHeaderTextStyle}" />
                    <TextBlock x:Name="LotNameText"
                               Text="Central Norte"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource Tx1Brush}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Border Background="{ThemeResource SuccessBackground}"
                                CornerRadius="3" Padding="6,1">
                            <TextBlock Text="EN LÍNEA"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="50"
                                       Foreground="{ThemeResource SuccessBrush}" />
                        </Border>
                        <TextBlock x:Name="LotStatusText"
                                   Text="0/0 spots"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource Tx3Brush}" />
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="MONITOREO" />
                <NavigationViewItem Tag="dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ViewAll" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="map" Content="Mapa de Spots">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Map" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="log" Content="Historial">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="ADMINISTRACIÓN" />
                <NavigationViewItem Tag="admin" Content="Gestión de Spots">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ContactInfo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="hardware" Content="Hardware / Arduino">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7F4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource StrokeBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Padding="16,0"
                        Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse x:Name="ArduinoLed" Width="6" Height="6"
                             Fill="{ThemeResource SuccessBrush}" />
                    <TextBlock x:Name="ArduinoStatusText"
                               Text="Arduino — desconectado"
                               FontSize="11"
                               Foreground="{ThemeResource Tx3Brush}" />
                </StackPanel>
                <Border Width="1" Height="12" Background="{ThemeResource StrokeBrush}" />
                <TextBlock x:Name="OccupancyStatusText"
                           Text="0/0 spots"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
                <Border Width="1" Height="12" Background="{ThemeResource StrokeBrush}" />
                <TextBlock x:Name="ClockText"
                           Text=""
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
                <TextBlock Text="Smart Parking Lot v1.0 · .NET 10"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}"
                           HorizontalAlignment="Right"
                           Margin="100,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
