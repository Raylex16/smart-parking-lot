<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Semantic palette aligned with Hi-Fi mockup -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="SuccessBrush"        Color="#0F7B0F" />
            <SolidColorBrush x:Key="SuccessBackground"   Color="#1A0F7B0F" />
            <SolidColorBrush x:Key="WarningBrush"        Color="#9D5D00" />
            <SolidColorBrush x:Key="WarningBackground"   Color="#1A9D5D00" />
            <SolidColorBrush x:Key="DangerBrush"         Color="#C42B1C" />
            <SolidColorBrush x:Key="DangerBackground"    Color="#1AC42B1C" />
            <SolidColorBrush x:Key="NeutralBrush"        Color="#5F000000" />
            <SolidColorBrush x:Key="NeutralBackground"   Color="#0A000000" />
            <SolidColorBrush x:Key="AccentLightBrush"    Color="#220891B2" />
            <SolidColorBrush x:Key="SubtleFillBrush"     Color="#08000000" />
            <SolidColorBrush x:Key="StrokeBrush"         Color="#15000000" />
            <SolidColorBrush x:Key="Stroke2Brush"        Color="#0E000000" />
            <SolidColorBrush x:Key="Tx1Brush"            Color="#E5000000" />
            <SolidColorBrush x:Key="Tx2Brush"            Color="#9B000000" />
            <SolidColorBrush x:Key="Tx3Brush"            Color="#72000000" />
            <SolidColorBrush x:Key="Layer1Brush"         Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="Layer2Brush"         Color="#F9F9F9" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="SuccessBrush"        Color="#6CCB5F" />
            <SolidColorBrush x:Key="SuccessBackground"   Color="#1A6CCB5F" />
            <SolidColorBrush x:Key="WarningBrush"        Color="#FCE100" />
            <SolidColorBrush x:Key="WarningBackground"   Color="#1AFCE100" />
            <SolidColorBrush x:Key="DangerBrush"         Color="#FF99A4" />
            <SolidColorBrush x:Key="DangerBackground"    Color="#1AFF99A4" />
            <SolidColorBrush x:Key="NeutralBrush"        Color="#72FFFFFF" />
            <SolidColorBrush x:Key="NeutralBackground"   Color="#10FFFFFF" />
            <SolidColorBrush x:Key="AccentLightBrush"    Color="#330891B2" />
            <SolidColorBrush x:Key="SubtleFillBrush"     Color="#0FFFFFFF" />
            <SolidColorBrush x:Key="StrokeBrush"         Color="#15FFFFFF" />
            <SolidColorBrush x:Key="Stroke2Brush"        Color="#0EFFFFFF" />
            <SolidColorBrush x:Key="Tx1Brush"            Color="#E5FFFFFF" />
            <SolidColorBrush x:Key="Tx2Brush"            Color="#9BFFFFFF" />
            <SolidColorBrush x:Key="Tx3Brush"            Color="#72FFFFFF" />
            <SolidColorBrush x:Key="Layer1Brush"         Color="#2B2B2B" />
            <SolidColorBrush x:Key="Layer2Brush"         Color="#323232" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Fluent card -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource Layer1Brush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="TileStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <!-- Section labels -->
    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource Tx3Brush}" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource Tx1Brush}" />
    </Style>

    <Style x:Key="TileLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{ThemeResource Tx2Brush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="TileValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource Tx1Brush}" />
        <Setter Property="LineHeight" Value="28" />
    </Style>

    <Style x:Key="TileSubTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{ThemeResource Tx3Brush}" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{ThemeResource Tx3Brush}" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Menlo, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource Tx1Brush}" />
    </Style>

</ResourceDictionary>
