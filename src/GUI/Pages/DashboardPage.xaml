<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartParkingLot.Gui.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SmartParkingLot.Gui.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Height="56" Padding="20,0" ColumnSpacing="10"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Uid="DashboardPageTitle"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource Tx1Brush}" />
                <TextBlock Text="{x:Bind ViewModel.LastUpdated, Mode=OneWay}"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
            </StackPanel>
            <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;"
                              AutomationProperties.Name="Actualizar"
                              FontSize="14" />
                    <TextBlock x:Uid="DashboardRefreshButton" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Tiles -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource TileStyle}" Grid.Column="0">
                        <StackPanel>
                            <TextBlock x:Uid="DashboardTileOccupied" Style="{StaticResource TileLabelTextStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.OccupiedCount, Mode=OneWay}" Style="{StaticResource TileValueTextStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" Style="{StaticResource TileSubTextStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileStyle}" Grid.Column="1">
                        <StackPanel>
                            <TextBlock x:Uid="DashboardTileAvailable" Style="{StaticResource TileLabelTextStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.AvailableCount, Mode=OneWay}" Style="{StaticResource TileValueTextStyle}" />
                            <TextBlock x:Uid="DashboardTileAvailableSub" Style="{StaticResource TileSubTextStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileStyle}" Grid.Column="2">
                        <StackPanel>
                            <TextBlock x:Uid="DashboardTileRequests" Style="{StaticResource TileLabelTextStyle}" />
                            <TextBlock Text="—" Style="{StaticResource TileValueTextStyle}" />
                            <TextBlock x:Uid="DashboardTileRequestsSub" Style="{StaticResource TileSubTextStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileStyle}" Grid.Column="3">
                        <StackPanel>
                            <TextBlock x:Uid="DashboardTileOccupancy" Style="{StaticResource TileLabelTextStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.OccupancyPct, Mode=OneWay}" Style="{StaticResource TileValueTextStyle}" />
                            <TextBlock x:Uid="DashboardTileOccupancySub" Style="{StaticResource TileSubTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Two cards row -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <StackPanel Padding="16">
                            <TextBlock x:Uid="DashboardZoneCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Zones, Mode=OneWay}" Margin="0,10,0,0">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="10" Orientation="Vertical" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ZoneRowVm">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Zone}" FontSize="12"
                                                           Foreground="{ThemeResource Tx2Brush}" />
                                                <TextBlock Text="{x:Bind Summary}" Grid.Column="1"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource Tx1Brush}" />
                                            </Grid>
                                            <ProgressBar Minimum="0" Maximum="100"
                                                         Value="{x:Bind OccupancyPct}" Height="4" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                        <StackPanel Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="DashboardAlertsCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.AlertBadgeText, Mode=OneWay}"
                                           Grid.Column="1"
                                           FontSize="11" Foreground="{ThemeResource Tx2Brush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Alerts, Mode=OneWay}" Margin="0,8,0,0">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="0" Orientation="Vertical" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AlertRowVm">
                                        <Grid Padding="0,7,0,7" BorderThickness="0,0,0,1"
                                              BorderBrush="{ThemeResource Stroke2Brush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon FontFamily="Segoe Fluent Icons"
                                                      Glyph="{x:Bind Glyph}" FontSize="14"
                                                      AutomationProperties.Name="{x:Bind GlyphName}"
                                                      Margin="0,0,10,0"
                                                      Foreground="{ThemeResource Tx2Brush}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{x:Bind Message}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="{ThemeResource Tx1Brush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="10" Foreground="{ThemeResource Tx3Brush}">
                                                    <Run Text="{x:Bind Source}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{x:Bind Time}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Gates summary -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Padding="16">
                        <TextBlock x:Uid="DashboardGatesCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Gates, Mode=OneWay}" Margin="0,10,0,0">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8" Orientation="Horizontal" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:GateRowVm">
                                    <Border Background="{ThemeResource Layer2Brush}"
                                            BorderBrush="{ThemeResource Stroke2Brush}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="12,10,12,10" Width="200">
                                        <StackPanel Spacing="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind GateId}" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource Tx1Brush}" />
                                                <TextBlock Text="{x:Bind StateLabel}" Grid.Column="1"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource Tx2Brush}" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind TypeLabel}"
                                                       FontSize="11" Foreground="{ThemeResource Tx3Brush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
