<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartParkingLot.Gui.Pages.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SmartParkingLot.Gui.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="56" Padding="20,0"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Uid="AdminPageTitle"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource Tx1Brush}" />
                <TextBlock x:Uid="AdminPageSubtitle"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Padding="16,8" Spacing="8"
                    Background="{ThemeResource Layer1Brush}"
                    BorderBrush="{ThemeResource Stroke2Brush}"
                    BorderThickness="0,0,0,1">
            <AutoSuggestBox x:Name="SearchBox"
                            x:Uid="AdminSearchBox"
                            MinWidth="320"
                            TextChanged="OnSearchTextChanged" />
            <ComboBox x:Name="TypeFilter" SelectedIndex="0" SelectionChanged="OnTypeFilterChanged">
                <ComboBoxItem x:Uid="AdminTypeFilterAll" Tag="" />
                <ComboBoxItem x:Uid="AdminTypeFilterEstandar" Tag="Estándar" />
                <ComboBoxItem Content="PMR" Tag="PMR" />
                <ComboBoxItem x:Uid="AdminTypeFilterMoto" Tag="Moto" />
            </ComboBox>
            <Button Click="OnRefreshClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph=""
                              AutomationProperties.Name="Actualizar"
                              FontSize="12" />
                    <TextBlock x:Uid="AdminRefreshButton" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Padding="14,8" Background="{ThemeResource Layer1Brush}"
                          BorderBrush="{ThemeResource StrokeBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AdminColId" Grid.Column="0"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock x:Uid="AdminColAddress" Grid.Column="1"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock x:Uid="AdminColType" Grid.Column="2"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock x:Uid="AdminColFloor" Grid.Column="3"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock x:Uid="AdminColState" Grid.Column="4"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                    </Grid>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredSpots, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SpotAdminRowVm">
                                <Grid Padding="14,8,14,8"
                                      BorderBrush="{ThemeResource Stroke2Brush}"
                                      BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Id}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource Tx1Brush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Address}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{ThemeResource Tx2Brush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Type}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{ThemeResource Tx2Brush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind Floor}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{ThemeResource Tx3Brush}" />
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind StateLabel}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{ThemeResource Tx2Brush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Padding="16,8"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,1,0,0">
            <TextBlock Text="{x:Bind ViewModel.FooterText, Mode=OneWay}"
                       FontSize="11"
                       Foreground="{ThemeResource Tx3Brush}" />
        </Grid>
    </Grid>
</Page>
