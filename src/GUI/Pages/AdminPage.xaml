<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartParkingLot.Gui.Pages.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="56" Padding="20,0"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Gestión de Spots"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource Tx1Brush}" />
                <TextBlock Text="Lista completa cargada desde la base de datos"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Padding="16,8" Spacing="8"
                    Background="{ThemeResource Layer1Brush}"
                    BorderBrush="{ThemeResource Stroke2Brush}"
                    BorderThickness="0,0,0,1">
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Buscar por ID, tipo, dirección..."
                            MinWidth="320"
                            TextChanged="OnSearchTextChanged" />
            <ComboBox x:Name="TypeFilter" SelectedIndex="0" SelectionChanged="OnTypeFilterChanged">
                <ComboBoxItem Content="Todos los tipos" Tag="" />
                <ComboBoxItem Content="Estándar" Tag="Estándar" />
                <ComboBoxItem Content="PMR" Tag="PMR" />
                <ComboBoxItem Content="Moto" Tag="Moto" />
            </ComboBox>
            <Button Click="OnRefreshClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="" FontSize="12" />
                    <TextBlock Text="Actualizar" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Padding="14,8" Background="{ThemeResource Layer1Brush}"
                          BorderBrush="{ThemeResource StrokeBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock Grid.Column="1" Text="DIRECCIÓN"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock Grid.Column="2" Text="TIPO"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock Grid.Column="3" Text="PISO"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                        <TextBlock Grid.Column="4" Text="ESTADO"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource Tx3Brush}" />
                    </Grid>
                    <StackPanel x:Name="RowsPanel" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Padding="16,8"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,1,0,0">
            <TextBlock x:Name="FooterText"
                       FontSize="11"
                       Foreground="{ThemeResource Tx3Brush}" />
        </Grid>
    </Grid>
</Page>
