<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartParkingLot.Gui.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SmartParkingLot.Gui.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="56" Padding="20,0"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Uid="HardwarePageTitle"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource Tx1Brush}" />
                <TextBlock x:Uid="HardwarePageSubtitle"
                           FontSize="11"
                           Foreground="{ThemeResource Tx3Brush}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Top row: connection + log -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="HardwareConnectionCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.ConnectionLabel, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource Tx1Brush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <StackPanel Spacing="6" Margin="0,6,0,0">
                                <TextBlock x:Uid="HardwarePortLabel" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBox Text="{x:Bind ViewModel.ConfigPort, Mode=OneWay}" PlaceholderText="COM3" />
                                <TextBlock x:Uid="HardwareBaudRateLabel" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBox Text="{x:Bind ViewModel.ConfigBaudRate, Mode=OneWay}" IsEnabled="False" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Command="{x:Bind ViewModel.ToggleConnectionCommand}"
                                        Style="{StaticResource AccentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons"
                                                  Glyph="{x:Bind ViewModel.ConnectButtonGlyph, Mode=OneWay}"
                                                  AutomationProperties.Name="{x:Bind ViewModel.ConnectButtonLabel, Mode=OneWay}"
                                                  FontSize="12" />
                                        <TextBlock Text="{x:Bind ViewModel.ConnectButtonLabel, Mode=OneWay}" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.ScanPortsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph=""
                                                  AutomationProperties.Name="Escanear puertos"
                                                  FontSize="12" />
                                        <TextBlock x:Uid="HardwareScanPortsButton" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.PortsListText, Mode=OneWay}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="11"
                                       Foreground="{ThemeResource Tx3Brush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="HardwareLiveLogCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Grid.Column="1">
                                    <ToggleSwitch IsOn="{x:Bind ViewModel.AutoScroll, Mode=TwoWay}"
                                                  AutomationProperties.Name="Auto-scroll del log"
                                                  OffContent="Pausado"
                                                  OnContent="Auto-scroll" />
                                    <Button Command="{x:Bind ViewModel.ClearLogCommand}"
                                            AutomationProperties.Name="Limpiar log">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph=""
                                                  AutomationProperties.Name="Limpiar"
                                                  FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Background="{ThemeResource Layer2Brush}"
                                    BorderBrush="{ThemeResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Height="240">
                                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LogLineVm">
                                                <TextBlock Text="{x:Bind Text}"
                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                           FontSize="11"
                                                           Foreground="{x:Bind Foreground}" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom row: actions + recent log file -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="6">
                            <TextBlock x:Uid="HardwareSensorCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock x:Uid="HardwareSensorDesc"
                                       FontSize="11"
                                       Foreground="{ThemeResource Tx3Brush}" />
                            <Grid ColumnSpacing="6" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{x:Bind ViewModel.SensorIds, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedSensorId, Mode=TwoWay}"
                                          PlaceholderText="Sensor" />
                                <ComboBox Grid.Column="1"
                                          SelectedIndex="0"
                                          SelectionChanged="OnStateSelectionChanged">
                                    <ComboBoxItem x:Uid="HardwareSensorStateOccupied" Tag="1" />
                                    <ComboBoxItem x:Uid="HardwareSensorStateFree" Tag="0" />
                                </ComboBox>
                                <Button Grid.Column="2"
                                        x:Uid="HardwarePublishButton"
                                        Command="{x:Bind ViewModel.EmitReadingCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Button Command="{x:Bind ViewModel.SimEntryIrCommand}">
                                    <TextBlock x:Uid="HardwareSimEntryButton" />
                                </Button>
                                <Button Command="{x:Bind ViewModel.SimExitIrCommand}">
                                    <TextBlock x:Uid="HardwareSimExitButton" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="HardwareFileLogCardTitle" Style="{StaticResource CardTitleTextStyle}" />
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.LoadFileLogCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph=""
                                                  AutomationProperties.Name="Cargar"
                                                  FontSize="12" />
                                        <TextBlock x:Uid="HardwareLoadFileButton" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.LogFilePath, Mode=OneWay}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="10"
                                       Foreground="{ThemeResource Tx3Brush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Background="{ThemeResource Layer2Brush}"
                                    BorderBrush="{ThemeResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Height="180">
                                <ScrollViewer>
                                    <TextBlock Text="{x:Bind ViewModel.LogFileText, Mode=OneWay}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="10"
                                               Foreground="{ThemeResource Tx2Brush}" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
