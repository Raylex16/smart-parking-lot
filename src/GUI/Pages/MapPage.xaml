<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SmartParkingLot.Gui.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Height="56" Padding="20,0"
              Background="{ThemeResource Layer1Brush}"
              BorderBrush="{ThemeResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mapa de Spots"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource Tx1Brush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Command bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Padding="16,8" Spacing="6"
                    BorderBrush="{ThemeResource Stroke2Brush}"
                    BorderThickness="0,0,0,1"
                    Background="{ThemeResource Layer1Brush}">
            <Button x:Name="EntryBtn" Click="OnEntryClick" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="" FontSize="12" />
                    <TextBlock Text="Solicitar entrada" />
                </StackPanel>
            </Button>
            <Button x:Name="ExitBtn" Click="OnExitClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="" FontSize="12" />
                    <TextBlock Text="Solicitar salida" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button x:Name="SimEntryIrBtn" Click="OnSimEntryIrClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="" FontSize="12" />
                    <TextBlock Text="Simular IR entrada" />
                </StackPanel>
            </Button>
            <Button x:Name="SimExitIrBtn" Click="OnSimExitIrClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="" FontSize="12" />
                    <TextBlock Text="Simular IR salida" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Body: map + right pane -->
        <Grid Grid.Row="2" Padding="16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <!-- Map -->
            <Border Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="14" Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="MapTitle" Text="Planta 1"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource Tx1Brush}" />
                                <TextBlock x:Name="MapSubtitle"
                                           FontSize="11"
                                           Foreground="{ThemeResource Tx3Brush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="10" Height="10" CornerRadius="2"
                                            Background="{ThemeResource Layer2Brush}"
                                            BorderBrush="{ThemeResource StrokeBrush}"
                                            BorderThickness="1" />
                                    <TextBlock Text="Libre" FontSize="10" Foreground="{ThemeResource Tx3Brush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="10" Height="10" CornerRadius="2"
                                            Background="{ThemeResource AccentLightBrush}"
                                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                            BorderThickness="1" />
                                    <TextBlock Text="Ocupado" FontSize="10" Foreground="{ThemeResource Tx3Brush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="EntryGatesStrip"
                                BorderBrush="{ThemeResource Stroke2Brush}"
                                BorderThickness="0,0,0,1"
                                Padding="0,6,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="ENTRADAS"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="80"
                                           Foreground="{ThemeResource Tx3Brush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <ItemsControl x:Name="EntryGatesPanel">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="ZonesPanel" Spacing="10" />

                        <Border BorderBrush="{ThemeResource Stroke2Brush}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="SALIDAS"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="80"
                                           Foreground="{ThemeResource Tx3Brush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <ItemsControl x:Name="ExitGatesPanel">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Click en un spot para cambiar su estado (publica evento de sensor)."
                                   FontSize="10"
                                   Foreground="{ThemeResource Tx3Brush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right pane: gate control + summary -->
            <StackPanel Grid.Column="1" Spacing="10">
                <Border Style="{StaticResource CardStyle}" Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Control de Gates" Style="{StaticResource CardTitleTextStyle}" />
                        <StackPanel x:Name="GateControlPanel" Spacing="8" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Resumen" Style="{StaticResource CardTitleTextStyle}" />
                        <Grid x:Name="SummaryGrid" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
